{
  "name": "Briefly Safety Policy",
  "version": "1.0.0",
  "description": "DX-01A Safety Helpers policy — defines which operations require human approval vs. auto-deny",
  "scope": "Human operator working with Claude Code / Powershell helpers",

  "allow": [
    "git status",
    "git status --short",
    "git diff --name-only",
    "git diff --cached --name-only",
    "git log --oneline",
    "git log --oneline -5",
    "git branch --show-current",
    "git rev-parse --show-toplevel",
    "git check-ignore",
    "pytest",
    "py_compile",
    "python -m py_compile",
    "uvicorn --help",
    "fastapi",
    "GET /health",
    "GET /healthz",
    "curl https://localhost:8001/health",
    "select-string (grep equivalent)",
    "Get-Content (read safe files only)",
    "Test-Path",
    "Get-Location",
    "Get-Clipboard",
    "Set-Clipboard"
  ],

  "ask": [
    "docker compose up",
    "docker compose build",
    "docker compose down",
    "docker compose --env-file .env.s3 up",
    "docker compose --env-file .env.s3 build",
    "git commit",
    "git push",
    "python -m pytest (in project root)",
    "npm run",
    "cd apps/backend",
    "running migrations",
    "edits in production code",
    "deleting files",
    "docker exec (non-env commands, e.g. docker exec -it container_name sh)"
  ],

  "deny": [
    "Get-Content .env.s3",
    "cat .env.s3",
    "type .env.s3",
    "docker inspect",
    "docker compose --env-file .env.s3 config",
    "docker exec env",
    "docker exec printenv",
    "printenv",
    "env | grep",
    "git add .",
    "git add -A",
    "echo $env:SUPABASE_TEST_JWT",
    "echo $env:AWS",
    "printing AWS_SECRET_ACCESS_KEY",
    "printing AWS_SESSION_TOKEN",
    "printing DOCUMENT_STORE_TYPE",
    "printing AWS_S3_BUCKET_NAME",
    "printing AWS_REGION",
    "printing AWS_ACCESS_KEY_ID",
    "AKIA[0-9A-Z]{16} in output",
    "IQoJb in output",
    "eyJ in output (JWT prefix)",
    "sb_secret in output",
    "sb_publishable in output",
    "-----BEGIN PRIVATE KEY----- in output",
    "supabase_service_role_key in output"
  ],

  "notes": [
    "This is a reminder policy, not a technical enforcement tool.",
    "Does NOT block Claude Code or Jarvis commands automatically.",
    "Human operator maintains final approval for all sensitive operations.",
    "Use bpreflight, bjwtsafe, bsafeenvs3, bredactlog, bsecretcheck helpers before sensitive operations."
  ]
}