# ─── Supabase (required for cloud auth) ────────────────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Planning Backend Integration (PM-04.4) ────────────────────────────────
# Set to 'true' to enable cloud planning REST API
# When false (default), TasksScreen uses local Yjs storage
VITE_PLANNING_BACKEND_ENABLED=false

# Planning service base URL.
# Development (electron:dev with Vite proxy): /api/planning
#   → Vite proxies to http://localhost:8003, avoiding CORS
# Deploy (nginx proxy on EC2): /api/planning
#   → nginx proxies to planning-service:8003 internally
# NOTE: Using relative URLs works for both dev proxy and nginx deploy.
VITE_PLANNING_SERVICE_URL=/api/planning

# Workspace service base URL.
# Development (electron:dev with Vite proxy): /api/workspace
#   → Vite proxies to http://localhost:8001, avoiding CORS
# Deploy (nginx proxy on EC2): /api/workspace
#   → nginx proxies to workspace-service:8001 internally
VITE_WORKSPACE_SERVICE_URL=/api/workspace
