# ─── Supabase (required for cloud auth) ────────────────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Planning Backend Integration (PM-04.4) ────────────────────────────────
# Set to 'true' to enable cloud planning REST API
# When false (default), TasksScreen uses local Yjs storage
VITE_PLANNING_BACKEND_ENABLED=false

# Planning service base URL.
# Development (electron:dev with Vite proxy): /api/planning
#   → Vite proxies to http://localhost:8003, avoiding CORS
# Deploy (nginx proxy on EC2): /api/planning
#   → nginx proxies to planning-service:8003 internally
# NOTE: Using relative URLs works for both dev proxy and nginx deploy.
VITE_PLANNING_SERVICE_URL=/api/planning

# Workspace service base URL.
# Development (electron:dev with Vite proxy): /api/workspace
#   → Vite proxies to http://localhost:8001, avoiding CORS
# Deploy (nginx proxy on EC2): /api/workspace
#   → nginx proxies to workspace-service:8001 internally
VITE_WORKSPACE_SERVICE_URL=/api/workspace

# ─── Schedule Backend Integration (PM-06F.4) ────────────────────────────────
# Set to 'true' to enable cloud schedule REST API
# When false (default), ScheduleScreen uses local localStorage
VITE_SCHEDULE_BACKEND_ENABLED=false

# Schedule service base URL.
# Development (electron:dev with Vite proxy): /api/schedule
#   → Vite proxies to http://localhost:8006, avoiding CORS
# Deploy (nginx proxy on EC2): /api/schedule
#   → nginx proxies to schedule-service:8006 internally
# NOTE: Using relative URLs works for both dev proxy and nginx deploy.
VITE_SCHEDULE_SERVICE_URL=/api/schedule

# ─── Development Proxy Target (PM-06F.4A) ─────────────────────────────────────
# Vite dev server proxy target for cloud service testing.
#
# Mode LOCAL (default — leave blank):
#   Vite proxies /api/* to localhost Docker services.
#   /api/workspace → http://localhost:8001 (stripped)
#   /api/planning   → http://localhost:8003 (stripped)
#   /api/schedule   → http://localhost:8006 (stripped)
#
# Mode CLOUD (set to production HTTPS endpoint):
#   Vite proxies /api/* to production, PRESERVING the /api/<service> path.
#   This allows Nginx on EC2 to route correctly.
#   /api/workspace → https://briefly.ddns.net/api/workspace (preserved)
#
# To test cloud schedule locally:
#   1. Set VITE_SCHEDULE_BACKEND_ENABLED=true
#   2. Set VITE_PLANNING_BACKEND_ENABLED=true
#   3. Set VITE_DEV_PROXY_TARGET=https://briefly.ddns.net
#   4. Run: cd apps/desktop && npm run dev
VITE_DEV_PROXY_TARGET=
